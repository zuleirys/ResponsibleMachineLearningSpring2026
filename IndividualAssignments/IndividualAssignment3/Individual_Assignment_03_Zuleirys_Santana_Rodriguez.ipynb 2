      "source": [
        "# Derive the adjusted Female-versus-Male probability effect from the model\n",
        "beta_female = model_glm.params[\"C(gender_factor, Treatment(reference='Male'))[T.Female]\"]\n",
        "float(np.exp(beta_female) / (1 - control + (control * np.exp(beta_female))))"
      ]
    },
    {
