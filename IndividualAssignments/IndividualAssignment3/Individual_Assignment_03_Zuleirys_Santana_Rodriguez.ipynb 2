      "source": [
        "# Derive the adjusted effect for defendants under 25 compared with ages 25-45\n",
        "beta_under25 = model_glm.params[\"C(age_factor, Treatment(reference='25 - 45'))[T.Less than 25]\"]\n",
        "float(np.exp(beta_under25) / (1 - control + (control * np.exp(beta_under25))))"
      ]
    },
    {
