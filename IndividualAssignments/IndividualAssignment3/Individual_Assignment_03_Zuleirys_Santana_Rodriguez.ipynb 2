      "source": [
        "# Produce fitted probabilities and convert them into predicted classes\n",
        "df[\"pred_prob\"] = model_glm.predict(df)\n",
        "df[\"pred_class\"] = np.where(df[\"pred_prob\"] >= 0.5, \"Recid\", \"No Recid\")"
