      "source": [
        "# Derive the adjusted Black-versus-White probability effect from the model\n",
        "control = np.exp(model_glm.params[\"Intercept\"]) / (1 + np.exp(model_glm.params[\"Intercept\"]))\n",
        "beta_black = model_glm.params[\"C(race_factor, Treatment(reference='Caucasian'))[T.African-American]\"]\n",
        "float(np.exp(beta_black) / (1 - control + (control * np.exp(beta_black))))"
      ]
    },
    {
